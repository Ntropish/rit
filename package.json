{
  "name": "rit",
  "version": "0.0.1",
  "description": "Redis + Git: versioned key-value store built on prolly trees",
  "type": "module",
  "main": "src/repo/index.ts",
  "browser": "src/browser.ts",
  "exports": {
    ".": "./src/repo/index.ts",
    "./src/store/sqlite.js": "./src/store/sqlite.ts",
    "./packages/rit-schema/src/index.js": "./packages/rit-schema/src/index.ts",
    "./packages/rit-sync/src/schemas.js": "./packages/rit-sync/src/schemas.ts",
    "./packages/rit-sync/src/html-schemas.js": "./packages/rit-sync/src/html-schemas.ts",
    "./packages/rit-sync/src/ci-schemas.js": "./packages/rit-sync/src/ci-schemas.ts",
    "./packages/rit-sync/src/index.js": "./packages/rit-sync/src/index.ts",
    "./src/sync/handlers.js": "./src/sync/handlers.ts",
    "./src/sync/blocks.js": "./src/sync/blocks.ts",
    "./src/sync/transport.js": "./src/sync/transport.ts"
  },
  "bin": {
    "rit": "src/cli/index.ts"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "node-html-parser": "^7.1.0",
    "ts-morph": "^27.0.2"
  }
}
